# ============================================================
# jobHunter -- n8n automation environment variables
# Copy this file to .env and fill in your values.
# In Railway: add these under Service > Variables.
# ============================================================

# RapidAPI (JSearch)
# https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
RAPIDAPI_KEY=your_rapidapi_key_here

# Supabase
# Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Google Gemini
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key_here

# App URL (Next.js deployment, used for webhook callbacks)
APP_URL=https://your-app.vercel.app

# Notifications (optional)
# Create a bot via @BotFather, get chat_id via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# n8n instance (Railway deployment)
N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=https
WEBHOOK_URL=https://your-n8n.railway.app/
N8N_EDITOR_BASE_URL=https://your-n8n.railway.app/

GENERIC_TIMEZONE=America/Argentina/Buenos_Aires
TZ=America/Argentina/Buenos_Aires

N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-this-to-something-strong

# Generate with: openssl rand -hex 16
N8N_ENCRYPTION_KEY=change-this-to-random-32-char-string

# PostgreSQL (Railway injects these automatically via ${{Postgres.PGXXX}})
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=${{Postgres.PGHOST}}
DB_POSTGRESDB_PORT=${{Postgres.PGPORT}}
DB_POSTGRESDB_DATABASE=${{Postgres.PGDATABASE}}
DB_POSTGRESDB_USER=${{Postgres.PGUSER}}
DB_POSTGRESDB_PASSWORD=${{Postgres.PGPASSWORD}}
